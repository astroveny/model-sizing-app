# ==============================================================================
# ml-sizer environment variables
# Copy this file to .env and fill in real values.
# ==============================================================================

# App identity
NEXT_PUBLIC_APP_NAME=ml-sizer

# ------------------------------------------------------------------------------
# LLM PROVIDER — choose one
# ------------------------------------------------------------------------------
# Options:
#   anthropic          → Anthropic Claude (default)
#   openai-compatible  → any OpenAI-compatible endpoint (Gemma, Kimi, Nemotron,
#                        Ollama, vLLM, TGI, Together, Groq, LM Studio, etc.)
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI-compatible (only used if LLM_PROVIDER=openai-compatible)
# Base URL MUST include /v1 — e.g. https://api.example.com/v1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# SQLite file path (relative to repo root or absolute). Mounted volume in Docker.
DATABASE_PATH=./data/ml-sizer.db

# ------------------------------------------------------------------------------
# Feature flags (optional)
# ------------------------------------------------------------------------------
# Default log level: error | warn | info | debug
LOG_LEVEL=info
